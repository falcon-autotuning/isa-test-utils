@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# ---------------------------------------
# Dependencies
# ---------------------------------------
find_dependency(PkgConfig REQUIRED)
pkg_check_modules(GLIB2 REQUIRED IMPORTED_TARGET glib-2.0)

# ---------------------------------------
# Targets
# ---------------------------------------
include("${CMAKE_CURRENT_LIST_DIR}/isa-test-utils-targets.cmake")

# ---------------------------------------
# Embed system (IMPORTANT)
# ---------------------------------------
include("${CMAKE_CURRENT_LIST_DIR}/embed_bundle.cmake")

# ---------------------------------------
# Provide namespace-safe alias
# ---------------------------------------
# Wrap the function with a namespaced name to avoid global pollution

function(isa_test_utils_embed_bundle)
  embed_bundle(${ARGV})
endfunction()

check_required_components(isa-test-utils)
