{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "description": "Default configuration (hidden, used as base)",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_ROOT": "${sourceDir}/vcpkg",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/my-vcpkg-triplets",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/ports",
        "CMAKE_MAKE_PROGRAM": "ninja",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "USE_CCACHE": "ON",
        "ENABLE_PCH": "ON",
        "BUILD_TESTS": "ON",
        "FALCON_CORE_BUILD_C_API": "ON"
      }
    },
    {
      "name": "linux-clang-debug",
      "description": "Linux Debug build with AddressSanitizer",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "CMAKE_PREFIX_PATH": "${sourceDir}/vcpkg_installed/x64-linux-dynamic/share;${sourceDir}/vcpkg_installed",
        "CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=lld -fsanitize=address",
        "CMAKE_SHARED_LINKER_FLAGS": "-fuse-ld=lld -fsanitize=address",
        "CMAKE_C_FLAGS": "-fsanitize=address -fno-omit-frame-pointer -g",
        "CMAKE_CXX_FLAGS": "-fsanitize=address -fno-omit-frame-pointer -g",
        "DENABLE_DEBUG_LOGS": true
      }
    },
    {
      "name": "linux-clang-release",
      "description": "Linux Release build with Clang",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "/usr/bin/clang",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "CMAKE_PREFIX_PATH": "${sourceDir}/vcpkg_installed/x64-linux-dynamic/share;${sourceDir}/vcpkg_installed",
        "CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=lld",
        "CMAKE_SHARED_LINKER_FLAGS": "-fuse-ld=lld"
      }
    },
    {
      "name": "linux-gcc-debug",
      "description": "Linux Debug build with GCC",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "CMAKE_PREFIX_PATH": "${sourceDir}/vcpkg_installed/x64-linux-dynamic/share;${sourceDir}/vcpkg_installed"
      }
    },
    {
      "name": "linux-gcc-release",
      "description": "Linux Release build with GCC",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "gcc",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "CMAKE_PREFIX_PATH": "${sourceDir}/vcpkg_installed/x64-linux-dynamic/share;${sourceDir}/vcpkg_installed"
      }
    },
    {
      "name": "windows-clang-cl-debug",
      "description": "Windows Debug build with clang-cl",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-win-llvm",
        "CMAKE_PREFIX_PATH": "${sourceDir}/vcpkg_installed/x64-win-llvm/share;${sourceDir}/vcpkg_installed"
      }
    },
    {
      "name": "windows-clang-cl-asan",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-win-llvm",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
        "CMAKE_C_FLAGS_INIT": "/Zi /Od /fsanitize=address",
        "CMAKE_CXX_FLAGS_INIT": "/Zi /Od /fsanitize=address"
      }
    },
    {
      "name": "windows-clang-cl-release",
      "description": "Windows Release build with clang-cl",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang-cl",
        "VCPKG_TARGET_TRIPLET": "x64-win-llvm",
        "CMAKE_PREFIX_PATH": "${sourceDir}/vcpkg_installed/x64-win-llvm/share;${sourceDir}/vcpkg_installed"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-clang-debug",
      "configurePreset": "linux-clang-debug",
      "jobs": 0
    },
    {
      "name": "linux-clang-release",
      "configurePreset": "linux-clang-release",
      "jobs": 0
    },
    {
      "name": "linux-gcc-debug",
      "configurePreset": "linux-gcc-debug",
      "jobs": 0
    },
    {
      "name": "linux-gcc-release",
      "configurePreset": "linux-gcc-release",
      "jobs": 0
    },
    {
      "name": "windows-clang-cl-debug",
      "configurePreset": "windows-clang-cl-debug",
      "jobs": 0
    },
    {
      "name": "windows-clang-cl-asan",
      "configurePreset": "windows-clang-cl-asan",
      "jobs": 0
    },
    {
      "name": "windows-clang-cl-release",
      "configurePreset": "windows-clang-cl-release",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "linux-clang-debug",
      "configurePreset": "linux-clang-debug"
    },
    {
      "name": "linux-clang-release",
      "configurePreset": "linux-clang-release"
    },
    {
      "name": "linux-gcc-debug",
      "configurePreset": "linux-gcc-debug"
    },
    {
      "name": "linux-gcc-release",
      "configurePreset": "linux-gcc-release"
    },
    {
      "name": "windows-clang-cl-debug",
      "configurePreset": "windows-clang-cl-debug"
    },
    {
      "name": "windows-clang-cl-asan",
      "configurePreset": "windows-clang-cl-asan"
    },
    {
      "name": "windows-clang-cl-release",
      "configurePreset": "windows-clang-cl-release"
    }
  ]
}
